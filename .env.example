# Copy to .env and fill in for local/dev use. All config is validated at boot by pydantic-settings.

ENVIRONMENT=dev

# Postgres — async URL used by the app, sync URL used by Alembic + the LangGraph checkpointer.
# Local (Docker Compose) default:
DATABASE_URL=postgresql+asyncpg://casewright:casewright@db:5432/casewright
DATABASE_URL_SYNC=postgresql+psycopg://casewright:casewright@db:5432/casewright
POSTGRES_USER=casewright
POSTGRES_PASSWORD=casewright
POSTGRES_DB=casewright
# Supabase (managed Postgres, pgvector already available — enable it once via the SQL editor:
# `create extension if not exists vector;`) — get the connection string from
# Project Settings → Database → Connection string → URI, then swap the driver prefix:
# DATABASE_URL=postgresql+asyncpg://postgres:<password>@<project-ref>.supabase.co:5432/postgres
# DATABASE_URL_SYNC=postgresql+psycopg://postgres:<password>@<project-ref>.supabase.co:5432/postgres
# See docs/deployment.md for the full walkthrough.

# Auth
JWT_SECRET=dev-only-change-me-before-any-real-deploy
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# Object storage (MinIO locally, S3-compatible in prod).
# Local (Docker Compose) default:
S3_ENDPOINT_URL=http://minio:9000
S3_PUBLIC_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=casewright
S3_SECRET_KEY=casewright123
S3_BUCKET=casewright-documents
S3_REGION=us-east-1
# Supabase Storage (S3-compatible — Project Settings → Storage → S3 Connection, "New access key"):
# S3_ENDPOINT_URL=https://<project-ref>.supabase.co/storage/v1/s3
# S3_PUBLIC_ENDPOINT_URL=  (same as S3_ENDPOINT_URL — Supabase Storage has no separate internal host)
# S3_ACCESS_KEY=<access key id from the S3 Connection panel>
# S3_SECRET_KEY=<secret access key>
# S3_BUCKET=casewright-documents   (create this bucket first, under Storage in the dashboard)
# S3_REGION=<the region shown in the S3 Connection panel>
# See docs/deployment.md for the full walkthrough.

# LLM / embeddings — required in phases 1+, unused by Phase 0.
# Provider: Ollama Cloud via its OpenAI-compatible API (plan §3 named Anthropic; swapped for
# Ollama Cloud when no ANTHROPIC_API_KEY was available — see docs/internal/PROJECT_LOG.md). Get a key at
# https://ollama.com/settings/keys.
OLLAMA_API_KEY=
OLLAMA_BASE_URL=https://ollama.com/v1
REASONING_MODEL=glm-5.2
FAST_MODEL=nemotron-3-nano:30b
VISION_MODEL=gemma4:31b
VOYAGE_API_KEY=

CORS_ORIGINS=http://localhost:5173,http://localhost:8080
