# Copy to .env and fill in for local/dev use. All config is validated at boot by pydantic-settings.

ENVIRONMENT=dev

# Postgres — async URL used by the app, sync URL used by Alembic + the LangGraph checkpointer
DATABASE_URL=postgresql+asyncpg://casewright:casewright@db:5432/casewright
DATABASE_URL_SYNC=postgresql+psycopg://casewright:casewright@db:5432/casewright
POSTGRES_USER=casewright
POSTGRES_PASSWORD=casewright
POSTGRES_DB=casewright

# Auth
JWT_SECRET=dev-only-change-me-before-any-real-deploy
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# Object storage (MinIO locally, S3-compatible in prod)
S3_ENDPOINT_URL=http://minio:9000
S3_PUBLIC_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=casewright
S3_SECRET_KEY=casewright123
S3_BUCKET=casewright-documents
S3_REGION=us-east-1

# LLM / embeddings — required in phases 1+, unused by Phase 0.
# Provider: Ollama Cloud via its OpenAI-compatible API (plan §3 named Anthropic; swapped for
# Ollama Cloud when no ANTHROPIC_API_KEY was available — see PROJECT_LOG.md). Get a key at
# https://ollama.com/settings/keys.
OLLAMA_API_KEY=
OLLAMA_BASE_URL=https://ollama.com/v1
REASONING_MODEL=glm-5.2
FAST_MODEL=nemotron-3-nano:30b
VISION_MODEL=gemma4:31b
VOYAGE_API_KEY=

CORS_ORIGINS=http://localhost:5173,http://localhost:8080
